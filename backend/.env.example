# ── TKU Backend Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# --- Security (REQUIRED in production) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# --- Token expiry (minutes) ---
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Database ---
# Local development:
DATABASE_URL=sqlite:///./tku.db
# Docker / Hugging Face Spaces (persistent storage):
# DATABASE_URL=sqlite:////data/tku.db

# --- CORS ---
# Development (allow all):
ALLOWED_ORIGINS=*
# Production (comma-separated, no spaces around commas):
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://staging.your-app.vercel.app

# --- Debug ---
DEBUG=False

# --- Dev server (used by run.py; not read by `uvicorn` when invoked directly) ---
# Override if 8000 is blocked (Windows WinError 10013 — a Hyper-V reserved port
# range or another process already bound to it). run.py also auto-tries
# PORT, PORT+1, PORT+2, PORT+3 before giving up.
HOST=127.0.0.1
PORT=8000
