# ── TKU Frontend Environment Variables ────────────────────────────────────────
# Copy this file to .env.local for local overrides.
# For production, set these in the Vercel dashboard (Settings → Environment Variables).

# Full base URL of the deployed backend API, including /api/v1
# Example: https://nyoman-sudarsana-tku-backend.hf.space/api/v1
# Leave empty to use the Vite dev-proxy (localhost development only)
VITE_API_BASE_URL=https://your-username-tku-backend.hf.space/api/v1
